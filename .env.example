# 运行模式: api 或 pool
MODE=api

APP_NAME=telegram-auto-message-server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 号池实例配置（支持多服务器部署）
POOL_INSTANCE_ID=pool-1
POOL_MAX_CONCURRENT_LOGINS=20
POOL_TOTAL_SHARDS=1
POOL_SHARD_INDEX=0
POOL_LOGIN_SCAN_INTERVAL_SECONDS=30
POOL_HEARTBEAT_INTERVAL_SECONDS=30
POOL_HEARTBEAT_TIMEOUT_SECONDS=120
POOL_LOGIN_TIMEOUT_SECONDS=30
POOL_LOGIN_MAX_RETRIES=3
POOL_LOGIN_RETRY_BACKOFF_SECONDS=2
POOL_LOGIN_RETRY_JITTER_MS=200
POOL_CLIENT_IDLE_TTL_SECONDS=300
POOL_CLIENT_MAX_FAILED_COUNT=3
POOL_CLIENT_CACHE_STATS_INTERVAL=100
POOL_ROUND_DEGRADED_SUCCESS_RATE_THRESHOLD=0.7
POOL_ROUND_DEGRADED_TIMEOUT_FAIL_THRESHOLD=3
POOL_SHARD_GUARD_ENABLED=true

# 号池参数档位参考（按场景择一覆盖）
# 开发单机：
# POOL_MAX_CONCURRENT_LOGINS=5
# POOL_LOGIN_TIMEOUT_SECONDS=20
# POOL_LOGIN_MAX_RETRIES=1
# POOL_LOGIN_RETRY_BACKOFF_SECONDS=1
# POOL_LOGIN_RETRY_JITTER_MS=50
# POOL_CLIENT_IDLE_TTL_SECONDS=120
# POOL_CLIENT_MAX_FAILED_COUNT=2
# POOL_ROUND_DEGRADED_SUCCESS_RATE_THRESHOLD=0.6
# POOL_ROUND_DEGRADED_TIMEOUT_FAIL_THRESHOLD=5

# 预发环境：
# POOL_MAX_CONCURRENT_LOGINS=10
# POOL_LOGIN_TIMEOUT_SECONDS=25
# POOL_LOGIN_MAX_RETRIES=2
# POOL_LOGIN_RETRY_BACKOFF_SECONDS=2
# POOL_LOGIN_RETRY_JITTER_MS=100
# POOL_CLIENT_IDLE_TTL_SECONDS=180
# POOL_CLIENT_MAX_FAILED_COUNT=3
# POOL_ROUND_DEGRADED_SUCCESS_RATE_THRESHOLD=0.7
# POOL_ROUND_DEGRADED_TIMEOUT_FAIL_THRESHOLD=3

# 生产多实例：
# POOL_MAX_CONCURRENT_LOGINS=20
# POOL_LOGIN_TIMEOUT_SECONDS=30
# POOL_LOGIN_MAX_RETRIES=3
# POOL_LOGIN_RETRY_BACKOFF_SECONDS=2
# POOL_LOGIN_RETRY_JITTER_MS=200
# POOL_CLIENT_IDLE_TTL_SECONDS=300
# POOL_CLIENT_MAX_FAILED_COUNT=3
# POOL_ROUND_DEGRADED_SUCCESS_RATE_THRESHOLD=0.8
# POOL_ROUND_DEGRADED_TIMEOUT_FAIL_THRESHOLD=2

# 数据库配置（默认使用 SQLite，也支持 MySQL）
# SQLite: sqlite:///storage/data.db
# MySQL: mysql+pymysql://root:root@127.0.0.1:3306/telegram_auto_message
MYSQL_DSN=sqlite:///storage/data.db

# Telegram
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# S3 配置（可选：不配置则自动使用本地持久存储 LOCAL_STORAGE_DIR）
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=

# 本地临时文件策略
# 若填写相对路径，将按“项目根目录”解析；Docker 场景建议映射到容器内固定目录。
LOCAL_TEMP_DIR=storage/temp_files
LOCAL_TEMP_MAX_BYTES=5368709120
LOCAL_TEMP_RETENTION_HOURS=168
LOCAL_CLEANUP_INTERVAL_MINUTES=60

# 本地持久化存储文件策略（在未启用 S3 时使用，用于长期保存上传的文件）
# 若填写相对路径，将按“项目根目录”解析；Docker 场景建议映射到容器内固定目录。
LOCAL_STORAGE_DIR=storage/persistent

# 免注册登录限速规则
# 格式为 '时间窗口秒数:最大允许次数'，用逗号分隔
# 默认：60:3,900:5,3600:10,86400:20 (1分钟最多3次，15分钟最多5次，1小时最多10次，24小时最多20次)
RATE_LIMIT_TRY_NOW_RULES=60:3,900:5,3600:10,86400:20

