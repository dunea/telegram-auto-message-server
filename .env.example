# 运行模式: api 或 pool
MODE=api

APP_NAME=telegram-auto-message-server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# MySQL
MYSQL_DSN=mysql+pymysql://root:root@127.0.0.1:3306/telegram_auto_message

# Telegram
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# S3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=

# 本地临时文件策略
LOCAL_TEMP_DIR=storage/temp_files
LOCAL_TEMP_MAX_BYTES=5368709120
LOCAL_TEMP_RETENTION_HOURS=168
LOCAL_CLEANUP_INTERVAL_MINUTES=60
