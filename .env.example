# 运行模式: api 或 pool
MODE=api

APP_NAME=telegram-auto-message-server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 号池实例配置（支持多服务器部署）
POOL_INSTANCE_ID=pool-1
POOL_MAX_CONCURRENT_LOGINS=20
POOL_TOTAL_SHARDS=1
POOL_SHARD_INDEX=0
POOL_LOGIN_SCAN_INTERVAL_SECONDS=30

# MySQL
MYSQL_DSN=mysql+pymysql://root:root@127.0.0.1:3306/telegram_auto_message

# Telegram
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# S3
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=

# 本地临时文件策略
# 若填写相对路径，将按“项目根目录”解析；Docker 场景建议映射到容器内固定目录。
LOCAL_TEMP_DIR=storage/temp_files
LOCAL_TEMP_MAX_BYTES=5368709120
LOCAL_TEMP_RETENTION_HOURS=168
LOCAL_CLEANUP_INTERVAL_MINUTES=60
